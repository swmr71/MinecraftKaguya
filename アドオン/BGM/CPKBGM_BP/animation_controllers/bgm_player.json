{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.bgm_player": {
      "initial_state": "default",
      "states": {
        "default": {
          "on_entry": [
            "/playsound my_custom.music @s"
          ],
          "transitions": [
            { "wait": "query.any_animation_finished" }
          ]
        },
        "wait": {
          "transitions": [
            { "default": "query.time_of_day > 0" }
          ]
        }
      }
    }
  }
}